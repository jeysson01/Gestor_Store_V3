# Supabase PostgreSQL (reemplaza Neon en producción)
DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
DATABASE_URL_UNPOOLED=postgres://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Opcional: solo para migración única Neon → Supabase
# NEON_DATABASE_URL_UNPOOLED=postgresql://...@...neon.tech/neondb?sslmode=require

# Supabase API (opcional, futuras integraciones)
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Número Yape que recibe los pagos
YAPE_PHONE=914713706

# Opcional: clave para webhook desde automatización del celular
YAPE_WEBHOOK_SECRET=tu_clave_secreta

# Webhook URL para notificaciones de Yape (ej. Webhook.site)
YAPE_WEBHOOK_URL=https://webhook.site/tu-uuid-aqui

# URL pública de la app. Para QR del kiosko en celular usa la IP de tu PC, no localhost.
# Ejemplo local: NEXT_PUBLIC_APP_URL=http://192.168.1.50:3002
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Autenticación
AUTH_SECRET=cambia-esta-clave-en-produccion
ADMIN_EMAIL=jeysson017@gmail.com
ADMIN_PASSWORD=Qquefue1?
